# =========================================================
# ENVIRONMENT CONFIGURATION
# =========================================================

ENVIRONMENT=staging

# =========================================================
# AWS CONFIGURATION
# =========================================================

AWS_REGION=eu-west-1

# =========================================================
# APPLICATION CONFIGURATION
# =========================================================

APP_NAME=frontend

APP_NAMESPACE=staging

APP_ECR_REPO=frontend-staging

APP_DEPLOYMENT=frontend

APP_CONTAINER=frontend

APP_K8S_PATH=k8s/apps/frontend

APP_DOCKER_CONTEXT=apps/frontend

APP_DOCKERFILE=apps/frontend/Dockerfile

# =========================================================
# IMAGE CONFIGURATION
# =========================================================

IMAGE_TAG=latest

# =========================================================
# KUBERNETES PLATFORM NAMESPACES
# =========================================================

JENKINS_NAMESPACE=jenkins

MONITORING_NAMESPACE=monitoring

TRIVY_NAMESPACE=trivy-system

EXTERNAL_SECRETS_NAMESPACE=external-secrets

# =========================================================
# EKS CONFIGURATION
# =========================================================

EKS_CLUSTER_NAME=devops-staging

# =========================================================
# DEPLOYMENT CONFIGURATION
# =========================================================

K8S_NAMESPACE=staging

K8S_DEPLOY_TIMEOUT=300s

# =========================================================
# SECURITY CONFIGURATION
# =========================================================

TRIVY_SEVERITY=HIGH,CRITICAL

TRIVY_EXIT_CODE=1

# =========================================================
# KANIKO CONFIGURATION
# =========================================================

KANIKO_CACHE=true

KANIKO_CACHE_REPO=cache

# =========================================================
# MONITORING CONFIGURATION
# =========================================================

GRAFANA_ENABLED=true

PROMETHEUS_ENABLED=true

LOKI_ENABLED=true

# =========================================================
# FUTURE GITOPS SUPPORT
# =========================================================

ARGOCD_ENABLED=false