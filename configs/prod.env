# =========================================================
# ENVIRONMENT CONFIGURATION
# =========================================================

ENVIRONMENT=prod

# =========================================================
# AWS CONFIGURATION
# =========================================================

AWS_REGION=eu-west-1

# =========================================================
# KUBERNETES CONFIGURATION
# =========================================================

APP_NAMESPACE=production
JENKINS_NAMESPACE=jenkins
MONITORING_NAMESPACE=monitoring
TRIVY_NAMESPACE=trivy-system

# =========================================================
# APPLICATION CONFIGURATION
# =========================================================
#
# PURPOSE
# ---------------------------------------------------------
# This configuration is completely reusable and portable.
#
# SAME Jenkins pipeline can deploy:
#
# - frontend
# - backend
# - auth-service
# - payments-service
# - future microservices
#
# WITHOUT modifying:
#
# - Jenkinsfile
# - Docker pipeline
# - Build stages
# - Deployment stages
#
# Only application variables change.
#
# =========================================================

# ---------------------------------------------------------
# APPLICATION NAME
# ---------------------------------------------------------

APP_NAME=frontend

# ---------------------------------------------------------
# CONTAINER IMAGE CONFIGURATION
# ---------------------------------------------------------

APP_ECR_REPO=frontend-prod

IMAGE_TAG=latest

# ---------------------------------------------------------
# KUBERNETES DEPLOYMENT CONFIGURATION
# ---------------------------------------------------------

APP_DEPLOYMENT=frontend

APP_CONTAINER=frontend

# ---------------------------------------------------------
# DOCKER BUILD CONFIGURATION
# ---------------------------------------------------------

APP_DOCKER_CONTEXT=apps/frontend

APP_DOCKERFILE=apps/frontend/Dockerfile

# ---------------------------------------------------------
# KUBERNETES MANIFEST LOCATION
# ---------------------------------------------------------

APP_K8S_PATH=k8s/apps/frontend

# ---------------------------------------------------------
# OPTIONAL FUTURE VARIABLES
# ---------------------------------------------------------
#
# These make future scaling easier.
#
# Examples:
#
# APP_SERVICE=frontend
# APP_PORT=80
# APP_HEALTHCHECK=/health
# APP_REPLICAS=2
#
# =========================================================