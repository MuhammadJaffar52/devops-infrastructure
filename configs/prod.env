ENVIRONMENT=prod

AWS_REGION=eu-west-1

FRONTEND_ECR_REPO=frontend-prod
BACKEND_ECR_REPO=backend-prod

APP_NAMESPACE=production
JENKINS_NAMESPACE=jenkins
MONITORING_NAMESPACE=monitoring
TRIVY_NAMESPACE=trivy-system

FRONTEND_DEPLOYMENT=frontend
BACKEND_DEPLOYMENT=backend

FRONTEND_CONTAINER=frontend
BACKEND_CONTAINER=backend

FRONTEND_DOCKER_CONTEXT=apps/frontend
BACKEND_DOCKER_CONTEXT=apps/backend

FRONTEND_DOCKERFILE=apps/frontend/Dockerfile
BACKEND_DOCKERFILE=apps/backend/Dockerfile
