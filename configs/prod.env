# =========================================================
# ENVIRONMENT
# =========================================================

ENVIRONMENT=prod

# =========================================================
# AWS
# =========================================================

AWS_REGION=eu-west-1

# =========================================================
# KUBERNETES NAMESPACES
# =========================================================

APP_NAMESPACE=production
JENKINS_NAMESPACE=jenkins
MONITORING_NAMESPACE=monitoring
TRIVY_NAMESPACE=trivy-system

# =========================================================
# GENERIC APPLICATION CONFIGURATION
# =========================================================
#
# SAME Jenkins pipeline can deploy:
# - frontend
# - backend
# - future microservices
#
# No Jenkinsfile modification required.
# =========================================================

APP_ECR_REPO=frontend-prod

APP_DEPLOYMENT=frontend

APP_CONTAINER=frontend

APP_DOCKER_CONTEXT=apps/frontend

APP_DOCKERFILE=apps/frontend/Dockerfile